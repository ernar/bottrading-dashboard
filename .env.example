# URL del backend (Flask + WebSocket). Es el valor por defecto del dashboard,
# pero puede sobrescribirse en runtime desde la pestaña "Ajustes" del propio
# dashboard (se guarda en el navegador y tiene prioridad sobre esta variable).
VITE_API_URL=http://localhost:5000
# Debe coincidir con API_TOKEN del backend (.env de la raíz). Déjalo vacío si
# el backend no usa token (uso puramente local). También editable en "Ajustes".
VITE_API_TOKEN=

# --- Login del dashboard (usuario único) ---
# Credenciales de acceso al dashboard. OJO: al ser una app de frontend, estos
# valores se incrustan en el bundle JS y son visibles para quien inspeccione el
# código del navegador. Sirven como puerta de acceso / disuasión, NO como
# seguridad real: la protección efectiva es el token del backend (X-API-Token).
# Si dejas usuario y contraseña vacíos, el login se desactiva.
VITE_AUTH_USER=tu-email@ejemplo.com
VITE_AUTH_PASS=tu-contraseña
